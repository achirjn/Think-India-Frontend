{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "http://api-thinkindiasvnit.ap-south-1.elasticbeanstalk.com/$1" },
    { "source": "/((?!api|_next|.*\\..*).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/site.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(favicon-.*\\.png|favicon\\.svg|apple-touch-icon\\.png|android-chrome-.*\\.png)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}